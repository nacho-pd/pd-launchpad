# Copy this to .env.local and fill in your Supabase project credentials
# NEVER commit .env or .env.local — they are gitignored

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase CLI authentication (for migrations, NOT for app runtime)
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-personal-access-token-here
